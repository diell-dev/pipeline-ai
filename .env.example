# ============================================================
# Pipeline AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI (for document generation)
ANTHROPIC_API_KEY=your-claude-api-key-here

# Email (for sending reports/invoices)
# RESEND_API_KEY=your-resend-api-key-here

# Stripe (for subscription billing — future)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cron (REQUIRED for the daily recurring-jobs cron on Vercel)
# Set this in the Vercel project so Vercel Cron sends it as a Bearer token;
# without it the nightly /api/internal/cron/spawn-recurring-jobs invocation
# is only authorized via the x-vercel-cron header. Generate with:
#   openssl rand -hex 32
CRON_SECRET=your-long-random-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
